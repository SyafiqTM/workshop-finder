generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int        @id @default(autoincrement())
  name      String
  email     String     @unique
  password  String
  phone     String?
  carModel  String?
  birthday  DateTime?
  currentMileage              Int?
  lastEngineOilChangeMileage Int?
  lastAtfChangeMileage       Int?
  mileageRecords             Json?
  role      String     @default("user")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  favorites Favorite[]
  reviews   Review[]
}

model Workshop {
  id          Int        @id @default(autoincrement())
  name        String
  address     String
  city        String
  latitude    Float
  longitude   Float
  phone       String
  opensAt     String     @default("09:00")
  closesAt    String     @default("18:00")
  schedule    String?    @db.Text
  description String     @db.Text
  services    String?    @db.Text
  images      String     @db.LongText
  status      String     @default("approved")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  favorites   Favorite[]
  reviews     Review[]
}

model Favorite {
  id         Int      @id @default(autoincrement())
  userId     Int
  workshopId Int
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@unique([userId, workshopId])
}

model Review {
  id         Int      @id @default(autoincrement())
  rating     Int
  comment    String   @db.Text
  status     String   @default("pending")
  userId     Int
  workshopId Int
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)
}
